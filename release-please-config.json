{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "package-name": "enji-guard-cli",
      "release-type": "simple",
      "changelog-path": "CHANGELOG.md",
      "include-component-in-tag": false,
      "changelog-sections": [
        {
          "type": "feat",
          "section": "Features"
        },
        {
          "type": "fix",
          "section": "Fixes"
        },
        {
          "type": "perf",
          "section": "Performance"
        },
        {
          "type": "revert",
          "section": "Reverts"
        },
        {
          "type": "chore",
          "section": "Maintenance",
          "hidden": true
        },
        {
          "type": "ci",
          "section": "CI",
          "hidden": true
        },
        {
          "type": "docs",
          "section": "Documentation",
          "hidden": true
        },
        {
          "type": "refactor",
          "section": "Refactoring",
          "hidden": true
        },
        {
          "type": "test",
          "section": "Tests",
          "hidden": true
        }
      ]
    }
  }
}
