{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "package-name": "enji-guard-cli",
      "release-type": "simple",
      "changelog-path": "CHANGELOG.md",
      "include-component-in-tag": false,
      "changelog-sections": [
        {
          "type": "feat",
          "section": "Features"
        },
        {
          "type": "fix",
          "section": "Fixes"
        },
        {
          "type": "perf",
          "section": "Performance"
        },
        {
          "type": "revert",
          "section": "Reverts"
        },
        {
          "type": "build",
          "section": "Build"
        },
        {
          "type": "chore",
          "section": "Maintenance"
        },
        {
          "type": "ci",
          "section": "CI"
        },
        {
          "type": "docs",
          "section": "Documentation"
        },
        {
          "type": "refactor",
          "section": "Refactoring"
        },
        {
          "type": "style",
          "section": "Style"
        },
        {
          "type": "test",
          "section": "Tests"
        }
      ]
    }
  }
}
