  "components": {
    "securitySchemes": {
      "sessionCookie": {
        "type": "apiKey",
        "in": "header",
        "name": "Cookie",
        "description": "Raw Cookie header copied from an authenticated browser session. Exact upstream cookie names are opaque."
      },
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Short-lived access JWT accepted by the gateway. Official long-lived API tokens are not available yet."
      }
    },
    "parameters": {
      "ProjectId": {
        "name": "projectId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "RepoId": {
        "name": "repoId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "pattern": "^repo_"
        }
      },
      "NotificationId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "ImprovementJobKind": {
        "name": "kind",
        "in": "path",
        "required": true,
        "schema": {
          "$ref": "#/components/schemas/ImprovementJobKind"
        }
      },
      "AuditActionKey": {
        "name": "actionKey",
        "in": "path",
        "required": true,
        "schema": {
          "$ref": "#/components/schemas/AuditActionKey"
        }
      }
    },
    "requestBodies": {
      "EmailPreferencesPatch": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/EmailPreferencesPatch"
            }
          }
        }
      }
    },
    "responses": {
      "GenericObject": {
        "description": "Object response not yet narrowed in the reconstructed contract.",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Authentication failed.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Forbidden": {
        "description": "The authenticated or refresh credential is not accepted.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
